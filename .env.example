# ── Backend Configuration ─────────────────────────────────────────────
# Database connection (Provided by your MySQL host)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=carpenter_db
DB_USER=root
DB_PASSWORD=your_password

# Security
JWT_SECRET=your_long_random_string_here
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173

# Optional: Google Auth
GOOGLE_CLIENT_ID=your_google_client_id

# Cloudinary (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Settings
RESET_ADMIN_PASSWORD=false
REFRESH_COOKIE_SECURE=true

# ── Frontend Configuration ────────────────────────────────────────────
# Point this to your backend URL (e.g. https://your-backend.onrender.com/api)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id
